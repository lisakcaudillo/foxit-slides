# =============================================================================
# foxit-slides — Environment Variables
# =============================================================================
# HOW TO USE:
#   1. Copy this file to `.env.local`:   cp .env.example .env.local
#   2. Fill in the values below.
#   3. NEVER commit `.env.local` — it is gitignored and holds real secrets.
#
# Only the "REQUIRED" block is needed to boot the app and use core AI features.
# Everything else is optional / feature-specific.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — core AI features will not work without these
# -----------------------------------------------------------------------------

# Anthropic (Claude) — primary AI provider for text/generation.
# Get a key: https://console.anthropic.com/ → Settings → API Keys
ANTHROPIC_API_KEY=

# OpenAI — image generation (DALL·E 3), vision/VLM judging, some card-engine calls.
# Pay-as-you-go billing. Get a key: https://platform.openai.com/ → API keys
OPENAI_API_KEY=

# Google Gemini — used as a vision/design "judge" model.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=


# -----------------------------------------------------------------------------
# STOCK IMAGES — needed only for the stock-image picker
# -----------------------------------------------------------------------------

# Pexels — https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay (alternative stock source) — https://pixabay.com/api/docs/
PIXABAY_API_KEY=


# -----------------------------------------------------------------------------
# FOXIT SDKs — commercial. Needed only for PDF redact/watermark/convert/sign.
# The app boots without these; Foxit-backed features stay disabled.
# -----------------------------------------------------------------------------

# Foxit PDF SDK (core PDF operations). SN + Key issued by Foxit.
FOXIT_SDK_SN=
FOXIT_SDK_KEY=

# Foxit PDF Conversion SDK (Office <-> PDF conversion).
FOXIT_CONVERSION_SDK_SN=
FOXIT_CONVERSION_SDK_KEY=

# Foxit eSign (OAuth client — separate product from the SDKs above).
FOXIT_ESIGN_CLIENT_ID=
FOXIT_ESIGN_CLIENT_SECRET=

# Optional Foxit resource paths (OCR / conversion resource dirs).
# Leave blank to use SDK defaults.
FOXIT_OCR_RESOURCE_PATH=
FOXIT_OCR_LANGUAGES=
FOXIT_CONVERSION_RES_PATH=


# -----------------------------------------------------------------------------
# OPTIONAL — provider / model selection (sensible defaults in code)
# -----------------------------------------------------------------------------

# Which AI provider to use ("anthropic" | "openai" | ...). Defaults in code.
AI_PROVIDER=
# Override the default model id for the selected provider.
AI_MODEL=

# Model overrides for specific tasks.
OPENAI_VISION_MODEL=
GEMINI_JUDGE_MODEL=
GEMINI_FALLBACK_MODELS=
VERIFY_MODEL=

# Azure OpenAI (only if routing OpenAI calls through Azure instead of direct).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT=
# Custom OpenAI-compatible base URL (proxy/gateway). Leave blank for default.
OPENAI_BASE_URL=


# -----------------------------------------------------------------------------
# OPTIONAL — tuning & dev toggles (safe to ignore)
# -----------------------------------------------------------------------------

# Card-engine tuning.
PLANNER_TEMPERATURE=
JUDGE_CONCURRENCY=
DIL_JUDGE_DISABLED=

# Debug logging / design-critic overlays.
DESIGN_LOG=
NEXT_PUBLIC_DESIGN_CRITIC=

# Local cache directory for source/content processing.
COMPOSE_CACHE_DIR=

# Internal render service base URL (defaults to localhost:PORT).
INTERNAL_RENDER_BASE_URL=

# NOTE: PORT is set by `npm run dev` (-p 3002). NODE_ENV is managed by Next.js
# — do not set these manually.
